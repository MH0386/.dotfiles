{
  "[dockercompose]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[lua]": {
    "editor.defaultFormatter": "sumneko.lua"
  },
  "[nss]": {
    "editor.defaultFormatter": "code-nature.nilesoft-shell-file-formatter"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "chat.agent.todoList": {
    "position": "default"
  },
  "chat.checkpoints.showFileChanges": true,
  "chat.edits2.enabled": true,
  "chat.emptyState.history.enabled": true,
  "chat.mcp.gallery.enabled": true,
  "chat.tools.terminal.autoApprove": {
    "/\\(.+\\)/s": {
      "approve": false,
      "matchCommandLine": true
    },
    "/\\{.+\\}/s": {
      "approve": false,
      "matchCommandLine": true
    },
    "/`.+`/s": {
      "approve": false,
      "matchCommandLine": true
    },
    "/^column\\b.*-c\\s+[0-9]{4,}/": false,
    "/^Compare-[a-z0-9]/i": true,
    "/^date\\b.*(-s|--set)\\b/": false,
    "/^find\\b.*-(delete|exec|execdir|fprint|fprintf|fls|ok|okdir)\\b/": false,
    "/^Format-[a-z0-9]/i": true,
    "/^git branch\\b.*-(d|D|m|M|-delete|-force)\\b/": false,
    "/^Measure-[a-z0-9]/i": true,
    "/^Select-[a-z0-9]/i": true,
    "/^Sort-[a-z0-9]/i": true,
    "/^sort\\b.*-(o|S)\\b/": false,
    "/^tree\\b.*-o\\b/": false,
    "basename": true,
    "cat": true,
    "cd": true,
    "chmod": false,
    "chown": false,
    "cmp": true,
    "column": true,
    "curl": false,
    "cut": true,
    "date": true,
    "dd": false,
    "del": false,
    "df": true,
    "dirname": true,
    "du": true,
    "echo": true,
    "erase": false,
    "eval": false,
    "file": true,
    "find": true,
    "findstr": true,
    "Get-ChildItem": true,
    "Get-Content": true,
    "Get-Date": true,
    "Get-Location": true,
    "Get-Random": true,
    "git branch": true,
    "git checkout": true,
    "git diff": true,
    "git grep": true,
    "git log": true,
    "git show": true,
    "git status": true,
    "grep": true,
    "head": true,
    "iex": false,
    "Invoke-Expression": false,
    "Invoke-RestMethod": false,
    "Invoke-WebRequest": false,
    "irm": false,
    "iwr": false,
    "Join-Path": true,
    "jq": false,
    "kill": false,
    "ls": true,
    "ps": false,
    "pwd": true,
    "rd": false,
    "readlink": true,
    "realpath": true,
    "Remove-Item": false,
    "ri": false,
    "rm": false,
    "rmdir": false,
    "Set-Acl": false,
    "Set-ItemProperty": false,
    "sleep": true,
    "sort": true,
    "sp": false,
    "Split-Path": true,
    "spps": false,
    "Start-Sleep": true,
    "stat": true,
    "Stop-Process": false,
    "tail": true,
    "taskkill": false,
    "taskkill.exe": false,
    "top": false,
    "tr": true,
    "tree": true,
    "wc": true,
    "wget": false,
    "Where-Object": true,
    "which": true,
    "Write-Host": true,
    "Write-Output": true,
    "xargs": false
  },
  "chat.useCloudButtonV2": true,
  "chat.useNestedAgentsMdFiles": true,
  "circleci.hostUrl": "",
  "diffEditor.codeLens": true,
  "diffEditor.experimental.showMoves": true,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.maxComputationTime": 0,
  "doppler.autocomplete.enable": true,
  "doppler.hover.enable": true,
  "editor.aiStats.enabled": true,
  "editor.autoIndentOnPaste": true,
  "editor.codeActionsOnSave": {
    "source.convertImportFormat": "always",
    "source.fixAll": "always",
    "source.fixAll.sortJSON": "always",
    "source.organizeImports.ruff": "always",
    "source.sort.json": "always",
    "source.unusedImports": "always"
  },
  "editor.defaultFormatter": "trunk.io",
  "editor.fontFamily": "JetBrainsMono Nerd Font Mono, ZedMono Nerd Font Mono, monospace",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.minimap.enabled": false,
  "editor.mouseWheelZoom": true,
  "errorLens.codeLensEnabled": true,
  "explorer.confirmDelete": false,
  "files.associations": {
    ".xonshrc": "xonsh",
    "*.sh.tmpl": "shellscript",
    "*.yaml.tmpl": "yaml",
    "*gitconfig": "properties",
    "*ignore": "ignore",
    "*zshrc": "shellscript",
    "compose-*.yaml": "dockercompose",
    "dot_xonshrc": "xonsh"
  },
  "files.autoSave": "afterDelay",
  "files.exclude": {
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*notifications/": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*plugins/": true
  },
  "files.watcherExclude": {
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*notifications/": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*plugins/": true
  },
  "gemini-cli.debug.logging.enabled": true,
  "geminicodeassist.inlineSuggestions.nextEditPredictions": true,
  "geminicodeassist.updateChannel": "Default",
  "git.allowNoVerifyCommit": true,
  "git.alwaysShowStagedChangesResourceGroup": true,
  "git.autofetch": true,
  "git.confirmNoVerifyCommit": false,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.fetchOnPull": true,
  "git.ignoreRebaseWarning": true,
  "git.openRepositoryInParentFolders": "always",
  "git.replaceTagsWhenPull": true,
  "github-actions.workflows.pinned.refresh.enabled": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.gitProtocol": "ssh",
  "githubPullRequests.pullBranch": "never",
  "gitlens.ai.gitkraken.model": "gemini:gemini-2.0-flash",
  "gitlens.ai.model": "gemini:gemini-2.5-flash",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "inlineChat.enableV2": true,
  "inlineChat.notebookAgent": true,
  "json.schemas": [],
  "mermaid-chat.enabled": true,
  "path-intellisense.autoSlashAfterDirectory": true,
  "path-intellisense.autoTriggerNextSuggestion": true,
  "path-intellisense.showHiddenFiles": true,
  "python.analysis.aiHoverSummaries": true,
  "python.analysis.autoFormatStrings": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.enableTroubleshootMissingImports": true,
  "python.analysis.generateWithTypeAnnotation": true,
  "python.analysis.includeAliasesFromUserFiles": true,
  "python.analysis.inlayHints.callArgumentNames": "all",
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.pytestParameters": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.supportDocstringTemplate": true,
  "python.analysis.typeCheckingMode": "basic",
  "python.languageServer": "Pylance",
  "python.testing.pytestArgs": [
    "tests"
  ],
  "python.testing.pytestEnabled": true,
  "remote.autoForwardPortsSource": "hybrid",
  "ruff.format.preview": true,
  "security.allowedUNCHosts": [
    "wsl.localhost"
  ],
  "security.promptForLocalFileProtocolHandling": false,
  "security.workspace.trust.untrustedFiles": "open",
  "snyk.folderConfigs": [
    {
      "baseBranch": "main",
      "folderPath": "/home/mohamed/Development/visualizr",
      "localBranches": [
        "ci",
        "error_handling",
        "main",
        "pycrucible",
        "settings",
        "vscode"
      ]
    }
  ],
  "snyk.securityAtInception.autoConfigureSnykMcpServer": true,
  "snyk.securityAtInception.executionFrequency": "On Code Generation",
  "snyk.trustedFolders": [
    "/home/mohamed/Development/visualizr"
  ],
  "terminal.external.windowsExec": "C:/Users/moham/AppData/Local/Programs/nu/bin/nu.exe",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.windows": "Nushell",
  "terminal.integrated.enableImages": true,
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.enableVisualBell": true,
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.ignoreBracketedPasteMode": true,
  "terminal.integrated.mouseWheelZoom": true,
  "terminal.integrated.profiles.linux": {
    "bash": {
      "icon": "terminal-bash",
      "path": "bash"
    },
    "fish": {
      "path": "fish"
    },
    "nu": {
      "path": "/usr/bin/nu"
    },
    "pwsh": {
      "icon": "terminal-powershell",
      "path": "pwsh"
    },
    "tmux": {
      "icon": "terminal-tmux",
      "path": "tmux"
    },
    "zsh": {
      "path": "zsh"
    }
  },
  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.suggest.providers": {
    "lsp": true,
    "terminal-suggest": true
  },
  "terminal.integrated.suggest.quickSuggestions": {
    "arguments": "on",
    "commands": "on",
    "unknown": "off"
  },
  "update.mode": "none",
  "window.titleBarStyle": "custom",
  "workbench.experimental.share.enabled": true,
  "chat.agentSessionsViewLocation": "view",
  "[shellscript]": {
    "editor.defaultFormatter": "mads-hartmann.bash-ide-vscode"
  },
  "window.zoomLevel": 1
}